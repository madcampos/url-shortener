{
	"name": "url-shortener",
	"version": "0.0.1",
	"private": true,
	"main": "src/index.mjs",
	"type": "module",
	"scripts": {
		"start": "wrangler dev --https-cert-path certs/server.crt --https-key-path certs/server.key",
		"generate:types": "wrangler types src/env.d.ts",
		"deploy": "wrangler deploy --minify --env production",
		"format": "dprint fmt --staged",
		"typecheck": "tsc --noEmit"
	},
	"author": "madcampos",
	"license": "MIT",
	"description": "A URL shortener",
	"devDependencies": {
		"@types/wicg-file-system-access": "2023.10.7",
		"dprint": "0.53.1",
		"typescript": "6.0.2",
		"wrangler": "4.79.0"
	}
}
