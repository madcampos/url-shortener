{
	"name": "url-shortener",
	"version": "0.0.1",
	"private": true,
	"main": "src/index.mjs",
	"type": "module",
	"scripts": {
		"bootstrap": "pnpm install && pnpm run generate:certs && pnpm run generate:types",
		"generate:certs": "mkdir certs && mkcert -key-file=certs/server.key -cert-file=certs/server.crt localhost",
		"generate:types": "wrangler types src/env.d.ts",
		"deploy": "wrangler deploy --minify",
		"format": "dprint fmt --staged",
		"typecheck": "tsc --noEmit"
	},
	"author": "madcampos",
	"license": "MIT",
	"description": "A URL shortener",
	"devDependencies": {
		"@types/wicg-file-system-access": "2023.10.7",
		"dprint": "0.53.1",
		"typescript": "6.0.2",
		"wrangler": "4.79.0"
	}
}
